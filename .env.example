# Lead Intelligence Pipeline — environment variables
# Copy to .env and fill in real values. Never commit .env.
# Vars are added here as each infra issue lands (see docs/RUNBOOK.md).

# --- n8n / Caddy (n8n/docker-compose.yml) — lives in n8n/.env on the VPS, issue #2 ---
# N8N_HOST=              # domain n8n is served on, e.g. n8n.example.com
# GENERIC_TIMEZONE=      # e.g. UTC or Europe/Berlin
# BASIC_AUTH_USER=       # Caddy basic-auth username for the n8n editor
# BASIC_AUTH_HASH=       # bcrypt hash from `docker run --rm caddy caddy hash-password`, never the plaintext password

# --- Supabase (leads DB, source of truth), issue #3 ---
# SUPABASE_URL=              # Project URL, e.g. https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY= # Secret key (sb_secret_... — new key system, legacy service_role JWT disabled). Server-side only (n8n credentials, Next.js server env). Bypasses RLS. Never expose to the browser or commit it.

# --- HubSpot (CRM delivery, write-only downstream), issue #4 ---
# HUBSPOT_TOKEN= # HubSpot Service Key (replaces legacy private app tokens as of 2026). Scopes: crm.objects.contacts.read + crm.objects.contacts.write only. Server-side only (n8n credentials, Next.js server env). Never commit it.

# --- Resend (error alerting for n8n workflows), issue #7 ---
# RESEND_API_KEY= # Resend API key, used only as an n8n Header Auth credential ("Resend API Key") for the Lead Intake - Error Alert workflow. Sender is Resend's default onboarding@resend.dev (no domain verification needed, but can only send to the account owner's own email — fine for a Wop-only alert). Formal alerting (Telegram/PagerDuty/etc) matures in Sprint 4. Never commit it.
