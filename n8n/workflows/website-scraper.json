      "id": "442febb9-98af-48d3-a8bb-74c9577a9dc7",
      "name": "Execute Workflow - Fetch Page",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.2,
      "position": [
        672,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const pageResults = $input.all().map((i) => i.json);\nconst pages = {};\nfor (const r of pageResults) {\n  pages[r.pageType] = {\n    status: r.status,\n    text: r.text || '',\n    url: r.url || null,\n    ...(r.reason ? { reason: r.reason } : {})\n  };\n}\n\nconst statuses = Object.values(pages).map((p) => p.status);\nconst okCount = statuses.filter((s) => s === 'ok').length;\nlet websiteStatus;\nif (okCount === statuses.length) websiteStatus = 'ok';\nelse if (okCount === 0) websiteStatus = 'failed';\nelse websiteStatus = 'partial';\n\nconst row = $('Parse robots.txt').first().json;\nconst existing = row.enrichment || {};\n\nconst enrichment = {\n  ...existing,\n  website: {\n    status: websiteStatus,\n    pages,\n    fetched_at: new Date().toISOString()\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
