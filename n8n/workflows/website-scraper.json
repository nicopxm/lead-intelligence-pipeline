      "id": "fc6b0cee-1bba-47e8-91b8-6200285682d0",
      "name": "Fetch robots.txt",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        0,
        0
      ],
      "retryOnFail": false,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const resp = $json;\nconst disallowed = [];\nconst bodyText = resp.body ?? resp.data;\n\nif (typeof bodyText === 'string' && (resp.statusCode === undefined || resp.statusCode < 400)) {\n  let inWildcardBlock = false;\n  for (const raw of bodyText.split(/\\r?\\n/)) {\n    const line = raw.split('#')[0].trim();\n    if (!line) continue;\n    const sepIdx = line.indexOf(':');\n    if (sepIdx === -1) continue;\n    const key = line.slice(0, sepIdx).trim().toLowerCase();\n    const value = line.slice(sepIdx + 1).trim();\n    if (key === 'user-agent') {\n      inWildcardBlock = value === '*';\n    } else if (key === 'disallow' && inWildcardBlock && value) {\n      disallowed.push(value);\n    }\n  }\n}\n\nconst row = $('Check Domain').item.json;\nreturn [{\n  json: {\n    id: row.id,\n    domain: row.domain.trim(),\n    enrichment: row.enrichment || {},\n    disallowedPrefixes: disallowed\n  }\n}];"
      },
      "id": "601193aa-ea1e-4976-b256-bbfbf4accb64",
      "name": "Parse robots.txt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $json;\nconst base = `https://${row.domain}`;\nconst disallowed = row.disallowedPrefixes || [];\n\nfunction isAllowed(path) {\n  return !disallowed.some((prefix) => path.startsWith(prefix));\n}\n\nconst plan = [\n  { pageType: 'home', primaryPath: '/', fallbackPath: null },\n  { pageType: 'about', primaryPath: '/about', fallbackPath: '/about-us' },\n  { pageType: 'pricing', primaryPath: '/pricing', fallbackPath: '/plans' }\n];\n\nreturn plan.map((p) => ({\n  json: {\n    pageType: p.pageType,\n    primaryUrl: base + p.primaryPath,\n    primaryAllowed: isAllowed(p.primaryPath),\n    fallbackUrl: p.fallbackPath ? base + p.fallbackPath : null,\n    fallbackAllowed: p.fallbackPath ? isAllowed(p.fallbackPath) : false\n  }\n}));"
      },
      "id": "30909120-b9e1-425a-8647-1e25cbe58188",
      "name": "Build Page Plan",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "workflowId": {
