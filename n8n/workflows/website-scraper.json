    {
      "parameters": {
        "jsCode": "const row = $('Check Domain').item.json;\nconst existing = row.enrichment || {};\nconst skippedPage = { status: 'skipped', text: '', url: null, reason: 'no_domain' };\n\nconst enrichment = {\n  ...existing,\n  website: {\n    status: 'skipped',\n    pages: {\n      home: skippedPage,\n      about: skippedPage,\n      pricing: skippedPage\n    },\n    fetched_at: null\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
      "id": "341f8c6b-6ea3-423d-8387-d4fdd644b417",
      "name": "Build Skipped Website (no domain)",
      "type": "n8n-nodes-base.code",
