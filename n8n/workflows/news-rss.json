    {
      "parameters": {
        "jsCode": "const row = $('Build News Query').item.json;\nconst existing = row.enrichment || {};\nconst enrichment = {\n  ...existing,\n  news: {\n    status: 'failed',\n    items: [],\n    reason: 'parse_failed',\n    fetched_at: new Date().toISOString()\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
      "id": "8e9f0a1b-2c3d-4e5f-6a7b-8c9d0e1f2a3b",
      "name": "Build Failed News (parse_failed)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        352,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $('Build News Query').item.json;\nconst existing = row.enrichment || {};\nconst channel = ($json.rss && $json.rss.channel) || {};\nlet rawItems = channel.item || [];\nif (!Array.isArray(rawItems)) rawItems = [rawItems];\n\nconst NINETY_DAYS_MS = 90 * 24 * 60 * 60 * 1000;\nconst cutoff = Date.now() - NINETY_DAYS_MS;\n\nconst items = rawItems\n  .map((it) => {\n    const dateObj = it.pubDate ? new Date(it.pubDate) : null;\n    const dateMs = dateObj && !isNaN(dateObj.getTime()) ? dateObj.getTime() : null;\n    let source = null;\n    if (it.source) {\n      source = typeof it.source === 'string' ? it.source : (it.source._ || null);\n    }\n    return {\n      title: it.title || '',\n      source,\n      date: dateMs !== null ? dateObj.toISOString() : null,\n      url: it.link || '',\n      _ms: dateMs\n    };\n  })\n  .filter((it) => it._ms !== null && it._ms >= cutoff)\n  .sort((a, b) => b._ms - a._ms)\n  .slice(0, 5)\n  .map(({ _ms, ...rest }) => rest);\n\nconst enrichment = {\n  ...existing,\n  news: {\n    status: 'ok',\n    items,\n    fetched_at: new Date().toISOString()\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
