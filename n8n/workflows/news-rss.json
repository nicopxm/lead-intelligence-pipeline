      "parameters": {
        "jsCode": "const row = $json;\nconst existing = row.enrichment || {};\nconst enrichment = {\n  ...existing,\n  news: {\n    status: 'skipped',\n    items: [],\n    reason: 'no_company',\n    fetched_at: new Date().toISOString()\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
