    },
    {
      "parameters": {
        "jsCode": "const row = $json;\nconst company = row.company.trim();\nconst q = `\"${company}\"`;\nconst rssUrl = `https://news.google.com/rss/search?q=${encodeURIComponent(q)}&hl=en-US&gl=US&ceid=US:en`;\n\nreturn [{ json: { id: row.id, enrichment: row.enrichment || {}, rssUrl } }];"
      },
