      ],
      "credentials": {
        "supabaseApi": {
          "id": "4pPsx2sAVgrzJm5n",
          "name": "Supabase Leads"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const row = $json;\nconst artifacts = (row.enrichment && row.enrichment.website && row.enrichment.website.raw_artifacts) || {};\n\nconst hasArtifacts = Object.values(artifacts).some((a) =>\n  a && (\n    (a.script_hosts && a.script_hosts.length) ||\n    (a.link_hosts && a.link_hosts.length) ||\n    a.meta_generator ||\n    (a.header_names && a.header_names.length) ||\n    (a.script_path_markers && a.script_path_markers.length)\n  )\n);\n\nreturn [{ json: { ...row, hasArtifacts } }];"
      },
      "id": "01580b3d-6f8a-411e-b288-5ca9a5d63abd",
      "name": "Check Has Artifacts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        160
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "cond-has-artifacts",
              "leftValue": "={{ $json.hasArtifacts }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "7e389ce4-d76a-421d-94e5-6b01803b22d9",
      "name": "Has Artifacts?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -224,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $('Check Has Artifacts').item.json;\nconst existing = row.enrichment || {};\nconst enrichment = {\n  ...existing,\n  tech_stack: {\n    status: 'skipped',\n    detected: [],\n    method: 'fingerprint',\n    reason: 'no_html'\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
      "id": "33ff6a3e-d47b-407a-bb0f-9e9d5f069b9b",
      "name": "Build Skipped Tech Stack",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        320
      ]
    },
    {
      "parameters": {
        "fileSelector": "/config/tech_fingerprints.json",
        "options": {}
      },
      "id": "e1b7dd48-1b3a-48e4-b790-f8df717c2c9e",
      "name": "Read Fingerprint Config",
      "type": "n8n-nodes-base.readWriteFile",
      "typeVersion": 1,
      "position": [
        0,
        0
      ],
      "alwaysOutputData": true,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "try {\n  const buffer = await this.helpers.getBinaryDataBuffer(0, 'data');\n  const rules = JSON.parse(buffer.toString('utf-8'));\n  if (!Array.isArray(rules)) throw new Error('fingerprint config is not an array');\n  return [{ json: { configOk: true, rules } }];\n} catch (e) {\n  return [{ json: { configOk: false, rules: [] } }];\n}\n"
      },
      "id": "4efa53a9-4e98-4c4f-b25a-d250f994cd05",
      "name": "Parse Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { configOk: false, rules: [] } }];"
      },
      "id": "1934d045-01d0-445b-93d5-e8e356b6207d",
      "name": "Config Read Failed",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
