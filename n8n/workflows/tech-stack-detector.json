                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "d802dc51-2617-4d56-8b25-85e5eac3cf14",
      "name": "Config Readable?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        448,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $('Check Has Artifacts').item.json;\nconst existing = row.enrichment || {};\nconst enrichment = {\n  ...existing,\n  tech_stack: {\n    status: 'failed',\n    detected: [],\n    method: 'fingerprint',\n    reason: 'config_unreadable'\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
      "id": "3fe8af5b-def6-4480-be7e-2efa530fcbda",
      "name": "Build Failed Config Object",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "function matches(rule, page) {\n  switch (rule.type) {\n    case 'script_host':\n      return (page.script_hosts || []).some((h) => h.includes(rule.pattern));\n    case 'link_host':\n      return (page.link_hosts || []).some((h) => h.includes(rule.pattern));\n    case 'meta_generator':\n      return !!page.meta_generator && page.meta_generator.toLowerCase().includes(rule.pattern.toLowerCase());\n    case 'header_name':\n      return (page.header_names || []).some((h) => h.toLowerCase() === rule.pattern.toLowerCase());\n    case 'script_path_marker':\n      return (page.script_path_markers || []).includes(rule.pattern);\n    default:\n      return false;\n  }\n}\n\nconst row = $('Check Has Artifacts').item.json;\nconst rules = $json.rules;\nconst rawArtifacts = (row.enrichment && row.enrichment.website && row.enrichment.website.raw_artifacts) || {};\n\nconst detected = new Set();\nfor (const page of Object.values(rawArtifacts)) {\n  if (!page) continue;\n  for (const rule of rules) {\n    if (matches(rule, page)) detected.add(rule.tool);\n  }\n}\n\nconst existing = row.enrichment || {};\nconst enrichment = {\n  ...existing,\n  tech_stack: {\n    status: 'ok',\n    detected: Array.from(detected).sort(),\n    method: 'fingerprint'\n  }\n};\n\nreturn [{ json: { id: row.id, enrichment } }];"
      },
      "id": "498ff70f-6cec-485b-80ea-3eb58d1cec69",
      "name": "Run Fingerprint Matching",
